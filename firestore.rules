rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'createdAt'])
        && data.keys().size() == 5
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 128
        && data.createdAt == request.time;
    }

    // --- Report Validation ---
    function isValidReport(data) {
      return data.keys().hasAll(['userId', 'content', 'contentType', 'riskLevel', 'score', 'summary', 'reasons', 'tips', 'isDeepfakeSuspected', 'timestamp'])
        && data.keys().size() == 10
        && data.userId == request.auth.uid
        && data.contentType in ['text', 'audio']
        && data.riskLevel in ['LOW', 'MEDIUM', 'HIGH', 'CRITICAL']
        && data.score is number && data.score >= 0 && data.score <= 100
        && data.summary is string && data.summary.size() <= 2000
        && data.reasons is list && data.reasons.size() <= 20
        && data.tips is list && data.tips.size() <= 20
        && data.isDeepfakeSuspected is bool
        && data.timestamp == request.time;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    match /reports/{reportId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidReport(incoming()) && isValidId(reportId);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      // Reports are generally immutable in this app, but allow minimal updates if needed
      allow update: if false; 
    }
  }
}
